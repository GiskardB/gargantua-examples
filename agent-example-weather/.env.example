# ═══════════════════════════════════════════════════════════════════
# Weather Agent — Environment (fully-local Ollama setup)
#
# Quick start:
#   1. Copy this file:   cp .env.example .env
#   2. Bring up stack:   docker compose up -d
#      (mongo + redis + ollama auto-pulls all 3 models on first boot)
#   3. Test:             open http://localhost:8080/chat
#
# Everything runs in containers. No API keys, no external services.
# ═══════════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────
# These values are used only for embedded/host-mode (mvn spring-boot:run).
# Inside docker-compose they are overridden by the service URLs.
MONGODB_URI=mongodb://localhost:27017/agent-example-weather
REDIS_URL=redis://localhost:6379

# ── Primary LLM (Ollama, local) ──────────────────────────────────
# Want a cloud provider instead? Set:
#   LLM_PRIMARY_PROVIDER=openai|anthropic|azure-openai
#   LLM_PRIMARY_MODEL=<model id>
#   LLM_PRIMARY_API_KEY=<your key>
#   LLM_PRIMARY_ENDPOINT=<only for azure-openai>
LLM_PRIMARY_PROVIDER=ollama
LLM_PRIMARY_MODEL=llama3.2:3b
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_ENDPOINT=http://localhost:11434
LLM_PRIMARY_TEMPERATURE=0.7
LLM_PRIMARY_MAX_TOKENS=1000

# ── Fallback LLM (Ollama, local) ─────────────────────────────────
# Auto-failover when primary fails (timeout, 5xx, rate limit).
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_MODEL=qwen2.5:3b
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_ENDPOINT=http://localhost:11434

# ── Routing LLM (Ollama, local) ──────────────────────────────────
# Used for skill routing and session summaries.
LLM_ROUTING_PROVIDER=ollama
LLM_ROUTING_MODEL=phi4-mini
LLM_ROUTING_API_KEY=
LLM_ROUTING_ENDPOINT=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────
# SERVER_PORT=8080
# SPRING_PROFILES_ACTIVE=dev
