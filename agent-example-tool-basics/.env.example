# ═══════════════════════════════════════════════════════════════════
# @AgentTool Basics Example — Environment (fully-local Ollama setup)
#
# Quick start (chat path):
#   1. Copy this file:   cp .env.example .env
#   2. Bring up stack:   docker compose up -d
#   3. Test:             open http://localhost:8080/chat
#
# For the test-only path you do NOT need this file — `mvn test`
# runs in embedded mode with no external infrastructure.
# ═══════════════════════════════════════════════════════════════════

# ── Infrastructure (only used in host/embedded mode) ─────────────
MONGODB_URI=mongodb://localhost:27017/agent-example-tool-basics
REDIS_URL=redis://localhost:6379

# ── Primary LLM (Ollama, local) ──────────────────────────────────
# Switch to a cloud provider by setting LLM_PRIMARY_PROVIDER to
# openai|anthropic|azure-openai and supplying LLM_PRIMARY_API_KEY.
LLM_PRIMARY_PROVIDER=ollama
LLM_PRIMARY_MODEL=llama3.2:3b
LLM_PRIMARY_API_KEY=
LLM_PRIMARY_ENDPOINT=http://localhost:11434
LLM_PRIMARY_TEMPERATURE=0.2
LLM_PRIMARY_MAX_TOKENS=500

# ── Fallback LLM (Ollama, local) ─────────────────────────────────
LLM_FALLBACK_PROVIDER=ollama
LLM_FALLBACK_MODEL=qwen2.5:3b
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_ENDPOINT=http://localhost:11434

# ── Routing LLM (Ollama, local) ──────────────────────────────────
LLM_ROUTING_PROVIDER=ollama
LLM_ROUTING_MODEL=phi4-mini
LLM_ROUTING_API_KEY=
LLM_ROUTING_ENDPOINT=http://localhost:11434
