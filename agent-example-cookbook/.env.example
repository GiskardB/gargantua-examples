# ═══════════════════════════════════════════════════════════════════
# Gargantua Agent — Environment Configuration
#
# Quick start:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the 3 values below (provider, model, API key)
#   3. Start infra:     docker compose up -d mongo redis ollama
#   4. Pull model:      docker compose exec ollama ollama pull phi4-mini
#   5. Run:             mvn spring-boot:run
# ═══════════════════════════════════════════════════════════════════

# ── Infrastructure ────────────────────────────────────────────────
# MongoDB, Redis, and Ollama are started via docker compose.
MONGODB_URI=mongodb://localhost:27017/my-agent
REDIS_URL=redis://localhost:6379

# ── Primary LLM — MANDATORY (3 values) ──────────────────────────
#
# Step 1: Choose your provider
#   openai       → OpenAI        (gpt-4o, gpt-4o-mini, ...)
#   anthropic    → Anthropic     (claude-sonnet-4, claude-haiku, ...)
#   azure-openai → Azure OpenAI  (requires LLM_PRIMARY_ENDPOINT)
#
# Step 2: Choose a model from that provider
#
# Step 3: Set the API key
#   OpenAI:    sk-...        (from platform.openai.com/api-keys)
#   Anthropic: sk-ant-...    (from console.anthropic.com)
#   Azure:     your resource key
#
LLM_PRIMARY_PROVIDER=openai
LLM_PRIMARY_MODEL=gpt-4o
LLM_PRIMARY_API_KEY=sk-your-key-here

# Only for azure-openai:
# LLM_PRIMARY_ENDPOINT=https://my-resource.openai.azure.com

# LLM_PRIMARY_TEMPERATURE=0.7
# LLM_PRIMARY_MAX_TOKENS=1000

# ── Fallback LLM (optional) ──────────────────────────────────────
# Auto-failover when primary fails (timeout, 5xx, rate limit).
# Backed by Resilience4j circuit breaker.
# LLM_FALLBACK_PROVIDER=anthropic
# LLM_FALLBACK_MODEL=claude-sonnet-4-20250514
# LLM_FALLBACK_API_KEY=sk-ant-...

# ── Routing Model ────────────────────────────────────────────────
# Runs locally via Ollama by default — zero API cost.
# Used for: skill routing, session summaries.
# Override only if you prefer a cloud provider for routing.
LLM_ROUTING_PROVIDER=ollama
LLM_ROUTING_MODEL=phi4-mini
LLM_ROUTING_ENDPOINT=http://localhost:11434

# ── Server ────────────────────────────────────────────────────────
# SERVER_PORT=8080
# SPRING_PROFILES_ACTIVE=dev
