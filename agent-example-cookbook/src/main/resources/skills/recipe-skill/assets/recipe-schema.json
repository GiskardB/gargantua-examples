{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recipe",
  "description": "A complete recipe with ingredients, steps and rough nutrition.",
  "type": "object",
  "required": ["name", "servings", "prepTimeMin", "cookTimeMin", "ingredients", "steps"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Recipe name, ideally evocative but practical"
    },
    "servings": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "prepTimeMin": {
      "type": "integer",
      "minimum": 0,
      "maximum": 240,
      "description": "Active preparation time in minutes"
    },
    "cookTimeMin": {
      "type": "integer",
      "minimum": 0,
      "maximum": 480,
      "description": "Hands-off cooking time in minutes"
    },
    "cuisine": {
      "type": "string",
      "description": "Cuisine label (italian, japanese, mexican, ...)"
    },
    "dietaryFlags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["vegan", "vegetarian", "gluten-free", "dairy-free", "nut-free", "low-carb", "high-protein"]
      },
      "uniqueItems": true
    },
    "ingredients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "amount", "unit"],
        "properties": {
          "name":   { "type": "string" },
          "amount": { "type": "number", "minimum": 0 },
          "unit":   { "type": "string", "description": "g | ml | tsp | tbsp | pc | cup ..." }
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "instruction"],
        "properties": {
          "order":           { "type": "integer", "minimum": 1 },
          "instruction":     { "type": "string", "minLength": 1 },
          "durationMinutes": { "type": "integer", "minimum": 0, "maximum": 240 }
        }
      }
    },
    "kcalPerServing": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5000,
      "description": "Approximate calories per serving"
    }
  }
}
