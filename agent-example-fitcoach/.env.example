# ══════════════════════════════════════════════════════════════════
# FitCoach AI — Environment Variables (template)
# Copy to .env and fill in the secrets before starting.
# ══════════════════════════════════════════════════════════════════

# ── Spring Profile ───────────────────────────────────────────────
# embedded  = in-memory, no Docker infrastructure needed
# dev       = development (hot-reload, debug logs)
# prod      = production (guardrails strict, no swagger)
SPRING_PROFILES_ACTIVE=dev

# ── Server ───────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Primary LLM (high-accuracy, medical/fitness domains) ────────
# Routed through Bifrost on http://localhost:8090. The actual provider
# (Azure OpenAI / OpenAI / Anthropic) is configured inside Bifrost via
# the AZURE_* / OPENAI_* keys at the bottom of this file.
LLM_PRIMARY_PROVIDER=openai
LLM_PRIMARY_MODEL=primary_model
LLM_PRIMARY_API_KEY=sk-bf-CHANGEME-bifrost-virtual-key
LLM_PRIMARY_ENDPOINT=http://localhost:8090/v1
LLM_PRIMARY_TEMPERATURE=0.7
LLM_PRIMARY_MAX_TOKENS=1000

# ── Fallback LLM (cheaper, general domains) ─────────────────────
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=primary_model
LLM_FALLBACK_API_KEY=sk-bf-CHANGEME-bifrost-virtual-key
LLM_FALLBACK_ENDPOINT=http://localhost:8090/v1

# ── Routing LLM (local via Ollama, zero-cost) ───────────────────
LLM_ROUTING_PROVIDER=ollama
LLM_ROUTING_MODEL=phi4-mini
LLM_ROUTING_API_KEY=
LLM_ROUTING_ENDPOINT=http://localhost:11434

# ── Infrastructure ───────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/fitcoach_ai
REDIS_URL=redis://localhost:6379

# ── Skill Routing ───────────────────────────────────────────────
ROUTING_STRATEGY=hybrid
ROUTING_THRESHOLD=0.82

# ── Ollama Model (auto-pulled at startup by ollama-init) ────────
OLLAMA_MODEL=phi4-mini

# ── Bifrost AI Gateway (Azure OpenAI provider) ──────────────────
# Read ONLY by Bifrost's entrypoint.sh, NOT by the application.
AZURE_OPENAI_API_KEY=CHANGEME-azure-resource-key
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
LLM_MODEL=gpt-4o-mini
# NOTE: do NOT set LLM_ROUTING_MODEL here — it's already set above for Ollama phi4-mini
